import { createFileRoute, useNavigate } from "@tanstack/react-router";
import { useMemo } from "react";
import { motion } from "framer-motion";
import { ArrowRight, CheckCircle2, HeartPulse, Sparkles } from "lucide-react";
import { AppShell } from "@/components/app-shell";
import { Skeleton } from "@/components/ui/skeleton";
import { AnimatedNumber, scoreTone, SubScoreBar } from "@/components/health-widgets";
import { useHealthScore } from "@/hooks/use-health-score";
import { takeLastSeenScore, type SubScore, type SubScoreKey } from "@/lib/health-score";
import type { HealthData } from "@/hooks/use-health-score";

export const Route = createFileRoute("/_authenticated/boost")({
  component: HealthScorePage,
});

const CTA_LABELS: Record<SubScoreKey, string> = {
  pinSeo: "Fix Pin SEO",
  boardStructure: "Fix Boards",
  profile: "Complete Profile",
  freshness: "Add Fresh Pins",
};

function HealthScorePage() {
  const navigate = useNavigate();
  const { report, data, isLoading } = useHealthScore();

  // A fix flow stashes the score the user last saw; climb from it so the
  // improvement is felt the moment they land back here.
  const animateFrom = useMemo(() => takeLastSeenScore(), []);

  // Where each sub-score's CTA goes. Profile deep-links straight to the first
  // missing field, never a generic settings page; freshness deep-links to
  // Create Pin pre-filtered to the stalest board.
  const goFix = (key: SubScoreKey) => {
    if (!data) return;
    switch (key) {
      case "pinSeo":
        return navigate({ to: "/health/pins" });
      case "boardStructure":
        return navigate({ to: "/health/boards" });
      case "profile": {
        const p = data.profile;
        if (!p.avatarSet) return navigate({ to: "/profile", search: { focus: "avatar" } });
        if (!p.socialLinked) return navigate({ to: "/profile", search: { focus: "pinterest" } });
        // Bio + website both live on the storefront — open its edit dialog.
        return navigate({ to: "/storefront", search: { collection: undefined, edit: 1 } });
      }
      case "freshness": {
        const stale = stalestBoardId(data);
        return navigate({ to: "/pins/create", search: { board: stale ?? undefined } });
      }
    }
  };

  return (
    <AppShell title="Pinterest Health" subtitle="One score. Everything holding your reach back.">
      <div className="mx-auto max-w-2xl">
        {isLoading || !report ? (
          <HealthSkeleton />
        ) : (
          <>
            {/* Big number */}
            <div className="rounded-3xl border border-border bg-surface p-6 text-center shadow-elevate">
              <div className="inline-flex items-center gap-1.5 rounded-full bg-primary/10 px-3 py-1 text-[11px] font-bold uppercase tracking-wide text-primary">
                <HeartPulse className="h-3.5 w-3.5" /> Pinterest Health Score
              </div>
              <div
                className={`mt-3 font-display text-7xl font-extrabold tracking-tight ${scoreTone(report.overall).text}`}
              >
                <AnimatedNumber value={report.overall} from={animateFrom} duration={1.4} />
                <span className="text-2xl font-bold text-muted-foreground">/100</span>
              </div>
              {/* Dynamic one-liner, driven by the weakest sub-score */}
              <p className="mx-auto mt-2 max-w-sm text-sm text-muted-foreground">
                {report.summary}
              </p>
            </div>

            {/* Sub-score bars */}
            <div className="mt-5 grid gap-3">
              {report.subScores.map((s) => (
                <SubScoreBar
                  key={s.key}
                  label={s.label}
                  score={s.score}
                  detail={subScoreDetail(s)}
                  onClick={() => goFix(s.key)}
                />
              ))}
            </div>

            {/* Ranked action list — worst first */}
            <div className="mt-8">
              <h2 className="mb-3 font-display text-lg font-semibold">Boost your score</h2>
              <div className="grid gap-2.5">
                {[...report.subScores]
                  .sort((a, b) => a.score - b.score)
                  .map((s, i) => (
                    <ActionRow key={s.key} sub={s} rank={i} onFix={() => goFix(s.key)} />
                  ))}
              </div>
            </div>
          </>
        )}
      </div>
    </AppShell>
  );
}

// The stalest board = one with no pin in the fresh window, oldest latest-pin
// first. Used to pre-filter Create Pin.
function stalestBoardId(data: HealthData): string | null {
  const latestByBoard = new Map<string, number>();
  for (const p of data.pins) {
    if (!p.collection_id) continue;
    const t = new Date(p.created_at).getTime();
    const prev = latestByBoard.get(p.collection_id) ?? 0;
    if (t > prev) latestByBoard.set(p.collection_id, t);
  }
  const cutoff = Date.now() - 30 * 86400000;
  const stale = data.boards
    .map((b) => ({ id: b.id, latest: latestByBoard.get(b.id) ?? 0 }))
    .filter((b) => b.latest < cutoff)
    .sort((a, b) => a.latest - b.latest);
  return stale[0]?.id ?? null;
}

function subScoreDetail(s: SubScore): string {
  if (s.score >= 100) return "Fully optimized";
  switch (s.key) {
    case "pinSeo":
      return `${s.failing} of ${s.total} pins need better titles or descriptions`;
    case "boardStructure":
      return `${s.failing} of ${s.total} boards have generic names or no description`;
    case "profile":
      return `${s.failing} of 4 profile items missing`;
    case "freshness":
      return `${s.failing} of ${s.total} boards have no pin from the last 30 days`;
  }
}

function ActionRow({ sub, rank, onFix }: { sub: SubScore; rank: number; onFix: () => void }) {
  const tone = scoreTone(sub.score);
  if (sub.score >= 100) {
    // Empty state: already perfect — celebrate it instead of a dead CTA.
    return (
      <div className="flex items-center gap-3 rounded-2xl border border-border bg-surface/60 px-4 py-3.5">
        <CheckCircle2 className="h-5 w-5 shrink-0 text-emerald-500" />
        <div className="min-w-0 flex-1">
          <p className="text-sm font-semibold">{sub.label}</p>
          <p className="text-[11px] text-muted-foreground">You're fully optimized here</p>
        </div>
        <span className="text-sm font-extrabold tabular-nums text-emerald-600">100%</span>
      </div>
    );
  }
  return (
    <motion.div
      initial={{ opacity: 0, y: 8 }}
      animate={{ opacity: 1, y: 0 }}
      transition={{ delay: rank * 0.06, duration: 0.3, ease: "easeOut" }}
      className={`flex items-center gap-3 rounded-2xl border px-4 py-3.5 ${
        rank === 0 ? "border-primary/40 bg-primary/5" : "border-border bg-surface"
      }`}
    >
      <div
        className={`grid h-9 w-9 shrink-0 place-items-center rounded-xl ${tone.bg} ${tone.text}`}
      >
        <Sparkles className="h-4.5 w-4.5" />
      </div>
      <div className="min-w-0 flex-1">
        <p className="text-sm font-semibold">{sub.label}</p>
        <p className={`text-[11px] font-bold tabular-nums ${tone.text}`}>{sub.score}%</p>
      </div>
      <button
        type="button"
        onClick={onFix}
        className="inline-flex shrink-0 items-center gap-1 rounded-full bg-gradient-primary px-3.5 py-2 text-xs font-bold text-primary-foreground shadow-glow transition hover:opacity-90"
      >
        {CTA_LABELS[sub.key]} <ArrowRight className="h-3.5 w-3.5" />
      </button>
    </motion.div>
  );
}

function HealthSkeleton() {
  return (
    <div>
      <div className="rounded-3xl border border-border bg-surface p-6 text-center">
        <Skeleton className="mx-auto h-6 w-44 rounded-full" />
        <Skeleton className="mx-auto mt-4 h-16 w-32 rounded-2xl" />
        <Skeleton className="mx-auto mt-3 h-3.5 w-64 rounded-full" />
      </div>
      <div className="mt-5 grid gap-3">
        {Array.from({ length: 4 }).map((_, i) => (
          <Skeleton key={i} className="h-[76px] rounded-2xl" />
        ))}
      </div>
    </div>
  );
}
