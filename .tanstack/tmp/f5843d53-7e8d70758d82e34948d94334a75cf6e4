import { createFileRoute, useNavigate } from "@tanstack/react-router";
import { useEffect, useMemo, useRef, useState } from "react";
import { useQueryClient } from "@tanstack/react-query";
import { motion } from "framer-motion";
import { toast } from "sonner";
import { CheckCheck, CheckCircle2, Image as ImageIcon, RotateCcw, Sparkles } from "lucide-react";
import { AppShell } from "@/components/app-shell";
import { Skeleton } from "@/components/ui/skeleton";
import { SwipeDeck } from "@/components/swipe-deck";
import { LiveScorePill } from "@/components/health-widgets";
import { supabase } from "@/integrations/supabase/client";
import { HEALTH_SCORE_QUERY_KEY, useHealthScore, type HealthData } from "@/hooks/use-health-score";
import {
  pinPassesSeo,
  pinSeoIssues,
  saveLastSeenScore,
  suggestPinDescription,
  suggestPinTitle,
  type HealthPin,
} from "@/lib/health-score";

export const Route = createFileRoute("/_authenticated/boost_/pins")({
  component: FixPinSeoPage,
});

type FixCard = HealthPin & {
  boardName: string | null;
  suggestedTitle: string;
  suggestedDescription: string;
  issues: string[];
};

type PrevValues = { title: string; description: string | null };

function FixPinSeoPage() {
  const navigate = useNavigate();
  const qc = useQueryClient();
  const { data, report, isLoading } = useHealthScore();

  // The deck is frozen from the FIRST load — applying a fix updates the query
  // cache (and the live score), but must not yank cards out from under the
  // swipe stack mid-flow, or undo/positioning breaks.
  const [deck, setDeck] = useState<FixCard[] | null>(null);
  useEffect(() => {
    if (deck !== null || !data) return;
    const boardNameById = new Map(data.boards.map((b) => [b.id, b.name]));
    setDeck(
      data.pins
        .filter((p) => !pinPassesSeo(p))
        .map((p) => {
          const boardName = p.collection_id ? (boardNameById.get(p.collection_id) ?? null) : null;
          return {
            ...p,
            boardName,
            suggestedTitle: suggestPinTitle(p, boardName),
            suggestedDescription: suggestPinDescription(p, boardName),
            issues: pinSeoIssues(p),
          };
        }),
    );
  }, [data, deck]);

  // Original values of every applied pin, for single-card undo and the bulk
  // "undo all" safety hatch — these are live pins, nothing ships irreversibly.
  const appliedRef = useRef<Map<string, PrevValues>>(new Map());
  const [statusById, setStatusById] = useState<Record<string, "approved" | "skipped">>({});
  const [pendingIds, setPendingIds] = useState<Set<string>>(new Set());
  const [bulkApplying, setBulkApplying] = useState(false);

  // Stash the score the user walked in with — the dashboard climbs from this
  // the moment they land back on it.
  const baselineSaved = useRef(false);
  useEffect(() => {
    if (report && !baselineSaved.current) {
      baselineSaved.current = true;
      saveLastSeenScore(report.overall);
    }
  }, [report]);

  // On leaving, refetch the truth (cache was patched optimistically) and let
  // any other pin surfaces pick up the new titles.
  useEffect(() => {
    return () => {
      void qc.invalidateQueries({ queryKey: HEALTH_SCORE_QUERY_KEY });
      void qc.invalidateQueries({ queryKey: ["dashboard-unmonetized-pins"] });
    };
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, []);

  const remaining = (deck ?? []).filter((c) => !statusById[c.id]);
  const done = deck !== null && deck.length > 0 && remaining.length === 0;
  const approvedCount = (deck ?? []).filter((c) => statusById[c.id] === "approved").length;

  // Live sub-score straight from the (optimistically patched) cache — every
  // approval nudges it up in real time.
  const pinSeoScore = report?.subScores.find((s) => s.key === "pinSeo")?.score ?? 0;

  const patchCache = (pinId: string, values: PrevValues) => {
    qc.setQueryData<HealthData>(HEALTH_SCORE_QUERY_KEY, (prev) =>
      prev
        ? { ...prev, pins: prev.pins.map((p) => (p.id === pinId ? { ...p, ...values } : p)) }
        : prev,
    );
  };

  const applyFix = async (card: FixCard) => {
    appliedRef.current.set(card.id, { title: card.title, description: card.description });
    patchCache(card.id, { title: card.suggestedTitle, description: card.suggestedDescription });
    setPendingIds((s) => new Set(s).add(card.id));
    const { error } = await supabase
      .from("pins")
      .update({ title: card.suggestedTitle, description: card.suggestedDescription })
      .eq("id", card.id);
    setPendingIds((s) => {
      const n = new Set(s);
      n.delete(card.id);
      return n;
    });
    if (error) {
      // Roll back the optimistic patch and put the card back in the queue.
      patchCache(card.id, appliedRef.current.get(card.id)!);
      appliedRef.current.delete(card.id);
      setStatusById((prev) => {
        const n = { ...prev };
        delete n[card.id];
        return n;
      });
      toast.error("Couldn't update that pin — it's back in the queue");
    }
  };

  const revertFix = async (card: FixCard) => {
    const prev = appliedRef.current.get(card.id);
    if (!prev) return;
    appliedRef.current.delete(card.id);
    patchCache(card.id, prev);
    const { error } = await supabase
      .from("pins")
      .update({ title: prev.title, description: prev.description })
      .eq("id", card.id);
    if (error) toast.error("Couldn't undo that change");
  };

  const handleDecide = (card: FixCard, decision: "approved" | "skipped") => {
    setStatusById((prev) => ({ ...prev, [card.id]: decision }));
    if (decision === "approved") void applyFix(card);
  };

  const handleUndo = (card: FixCard, decision: "approved" | "skipped") => {
    setStatusById((prev) => {
      const n = { ...prev };
      delete n[card.id];
      return n;
    });
    if (decision === "approved") void revertFix(card);
  };

  const approveAll = async () => {
    if (remaining.length === 0 || bulkApplying) return;
    setBulkApplying(true);
    const targets = [...remaining];
    setStatusById((prev) => {
      const n = { ...prev };
      for (const c of targets) n[c.id] = "approved";
      return n;
    });
    await Promise.all(targets.map((c) => applyFix(c)));
    setBulkApplying(false);
  };

  const undoAll = async () => {
    const applied = (deck ?? []).filter((c) => appliedRef.current.has(c.id));
    setStatusById({});
    await Promise.all(applied.map((c) => revertFix(c)));
    toast.success("All changes reverted");
  };

  const backToScore = () => navigate({ to: "/health" });

  return (
    <AppShell title="Fix Pin SEO" backButton backTo="/health" hideBottomNav>
      <div className="mx-auto flex h-[calc(100dvh-6.5rem)] max-w-md flex-col px-1">
        {/* Live score — the feedback loop, always on screen */}
        <div className="flex shrink-0 items-center justify-center pb-3">
          <LiveScorePill label="Pin SEO score" score={pinSeoScore} />
        </div>

        {isLoading || deck === null ? (
          <DeckSkeleton />
        ) : deck.length === 0 ? (
          <OptimizedState onBack={backToScore} />
        ) : done ? (
          <DoneState
            approvedCount={approvedCount}
            total={deck.length}
            score={pinSeoScore}
            busy={bulkApplying || pendingIds.size > 0}
            onUndoAll={approvedCount > 0 ? undoAll : undefined}
            onBack={backToScore}
          />
        ) : (
          <>
            <SwipeDeck
              items={remaining}
              pendingIds={pendingIds}
              renderCard={(card) => <PinFixCard card={card} />}
              onDecide={handleDecide}
              onUndo={handleUndo}
              approveLabel="Apply fix"
            />
            <motion.button
              whileTap={{ scale: 0.98 }}
              onClick={approveAll}
              disabled={bulkApplying}
              className="mt-2.5 inline-flex w-full shrink-0 items-center justify-center gap-1.5 rounded-2xl border-2 border-primary bg-surface px-3 py-3 text-[13px] font-bold text-primary transition disabled:opacity-40"
            >
              <CheckCheck className="h-4 w-4" /> Approve all ({remaining.length})
            </motion.button>
          </>
        )}
      </div>
    </AppShell>
  );
}

function PinFixCard({ card }: { card: FixCard }) {
  return (
    <div className="flex h-full flex-col">
      <div className="relative h-2/5 shrink-0 bg-surface-2">
        {card.image_url ? (
          <img
            src={card.image_url}
            alt=""
            className="h-full w-full object-cover"
            draggable={false}
          />
        ) : (
          <div className="grid h-full place-items-center text-muted-foreground">
            <ImageIcon className="h-8 w-8" />
          </div>
        )}
        <div className="absolute left-2 top-2 flex flex-wrap gap-1">
          {card.issues.map((issue) => (
            <span
              key={issue}
              className="rounded-full bg-black/55 px-2 py-0.5 text-[10px] font-semibold text-white backdrop-blur"
            >
              {issue}
            </span>
          ))}
        </div>
      </div>
      <div className="no-scrollbar min-h-0 flex-1 space-y-3 overflow-y-auto p-4">
        <div>
          <p className="text-[10px] font-bold uppercase tracking-wide text-muted-foreground">Now</p>
          <p className="mt-0.5 line-clamp-1 text-sm font-semibold text-muted-foreground">
            {card.title.trim() || "(no title)"}
          </p>
          <p className="mt-0.5 line-clamp-2 text-xs text-muted-foreground/70">
            {card.description?.trim() || "(no description)"}
          </p>
        </div>
        <div className="rounded-2xl bg-primary/5 p-3 ring-1 ring-primary/20">
          <p className="flex items-center gap-1 text-[10px] font-bold uppercase tracking-wide text-primary">
            <Sparkles className="h-3 w-3" /> Suggested
          </p>
          <p className="mt-1 text-sm font-semibold leading-snug">{card.suggestedTitle}</p>
          <p className="mt-1.5 text-xs leading-relaxed text-foreground/80">
            {card.suggestedDescription}
          </p>
        </div>
      </div>
    </div>
  );
}

export function OptimizedState({ onBack }: { onBack: () => void }) {
  return (
    <div className="grid flex-1 place-items-center">
      <div className="rounded-3xl border border-border bg-surface p-10 text-center shadow-elevate">
        <CheckCircle2 className="mx-auto h-12 w-12 text-emerald-500" />
        <h2 className="mt-3 font-display text-xl font-bold">You're fully optimized here</h2>
        <p className="mt-1 text-sm text-muted-foreground">
          Nothing needs fixing — every item already passes the check.
        </p>
        <button
          onClick={onBack}
          className="mt-5 inline-flex items-center gap-1.5 rounded-full bg-gradient-primary px-5 py-2.5 text-sm font-bold text-primary-foreground shadow-glow"
        >
          Back to Health Score
        </button>
      </div>
    </div>
  );
}

export function DoneState({
  approvedCount,
  total,
  score,
  busy,
  onUndoAll,
  onBack,
}: {
  approvedCount: number;
  total: number;
  score: number;
  busy: boolean;
  onUndoAll?: () => void;
  onBack: () => void;
}) {
  return (
    <div className="grid flex-1 place-items-center">
      <motion.div
        initial={{ opacity: 0, scale: 0.94 }}
        animate={{ opacity: 1, scale: 1 }}
        transition={{ type: "spring", stiffness: 320, damping: 26 }}
        className="w-full rounded-3xl border border-border bg-surface p-8 text-center shadow-elevate"
      >
        <CheckCircle2 className="mx-auto h-12 w-12 text-emerald-500" />
        <h2 className="mt-3 font-display text-xl font-bold">
          {approvedCount} of {total} fixed
        </h2>
        {/* The score is already climbing in the pill above — spell it out too */}
        <p className="mt-1 text-sm text-muted-foreground">
          Your score is now <span className="font-bold text-foreground">{score}%</span>
          {busy ? " — saving…" : ""}
        </p>
        <button
          onClick={onBack}
          className="mt-5 inline-flex w-full items-center justify-center gap-1.5 rounded-2xl bg-gradient-primary px-5 py-3 text-sm font-bold text-primary-foreground shadow-glow"
        >
          See your new Health Score
        </button>
        {onUndoAll && (
          <button
            onClick={onUndoAll}
            disabled={busy}
            className="mt-2.5 inline-flex w-full items-center justify-center gap-1.5 rounded-2xl border border-border px-5 py-3 text-sm font-semibold text-muted-foreground transition hover:text-foreground disabled:opacity-50"
          >
            <RotateCcw className="h-4 w-4" /> Undo all changes
          </button>
        )}
      </motion.div>
    </div>
  );
}

export function DeckSkeleton() {
  return (
    <div className="flex flex-1 flex-col">
      <div className="relative min-h-0 flex-1">
        <Skeleton className="absolute inset-0 rounded-3xl" />
      </div>
      <div className="mt-3 flex shrink-0 gap-2.5">
        <Skeleton className="h-[52px] w-24 rounded-2xl" />
        <Skeleton className="h-[52px] flex-1 rounded-2xl" />
      </div>
    </div>
  );
}
